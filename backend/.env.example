ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Set to true to bypass the Anthropic API entirely and use a deterministic
# fake client. Useful for local smoke tests; never use in production.
USE_FAKE_LLM=false
DATABASE_URL=sqlite:///./data/app.db
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
